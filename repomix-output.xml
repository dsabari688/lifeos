import React, { useState, useEffect } from "react";
import { 
  Menu, X, Bell, LayoutDashboard, Calendar, RefreshCw, Target, 
  LineChart, Cpu, Clock, Settings, LogOut, Terminal, ChevronRight, Zap, Info
